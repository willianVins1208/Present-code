                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories",
                "{{categoryId}}"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"category fetch status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"category id matches\", function () {",
                  "  var category = pm.response.json();",
                  "  pm.expect(String(category.id)).to.eql(String(pm.collectionVariables.get(\"categoryId\")));",
                  "});",
                  "pm.test(\"category description matches variable\", function () {",
                  "  var category = pm.response.json();",
                  "  pm.expect(category.description).to.eql(pm.collectionVariables.get(\"categoryDescription\"));",
                  "});"
