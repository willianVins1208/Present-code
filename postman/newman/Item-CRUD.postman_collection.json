    {
      "name": "03 Item",
      "item": [
        {
          "name": "Create Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{itemName}}\",\n  \"description\": \"{{itemDescription}}\",\n  \"price\": {{itemPrice}},\n  \"categoryId\": {{categoryId}},\n  \"supplierId\": {{supplierId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "items"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"item status is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var createdItem = pm.response.json();",
                  "pm.collectionVariables.set(\"itemId\", createdItem.id);",
                  "pm.test(\"item has linked category\", function () {",
                  "  pm.expect(createdItem.category.id).to.eql(Number(pm.collectionVariables.get(\"categoryId\")));",
                  "});",
                  "pm.test(\"item has linked supplier\", function () {",
                  "  pm.expect(createdItem.supplier.id).to.eql(Number(pm.collectionVariables.get(\"supplierId\")));",
                  "});",
                  "pm.test(\"item name matches variable\", function () {",
                  "  pm.expect(createdItem.name).to.eql(pm.collectionVariables.get(\"itemName\"));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
