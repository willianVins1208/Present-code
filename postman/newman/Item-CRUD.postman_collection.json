  "item": [
    {
      "name": "00 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"health response contains ok status\", function () {",
                  "  var healthResponse = pm.response.json();",
                  "  pm.expect(healthResponse.status).to.eql(\"ok\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "01 Category",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{categoryName}}\",\n  \"description\": \"{{categoryDescription}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "categories"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"category status is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var category = pm.response.json();",
                  "pm.collectionVariables.set(\"categoryId\", category.id);",
                  "pm.test(\"category id saved\", function () {",
                  "  pm.expect(category.id).to.be.a(\"number\");",
                  "});",
                  "pm.test(\"category name matches variable\", function () {",
                  "  pm.expect(category.name).to.eql(pm.collectionVariables.get(\"categoryName\"));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Category By Id",
          "request": {
            "method": "GET",
            "header": [],
