{
  "info": {
    "_postman_id": "22d4d67c-56dd-4dcb-bec0-78ca05d4ce10",
    "name": "Item CRUD API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing the Item CRUD API."
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"health response contains ok status\", function () {",
              "  var healthResponse = pm.response.json();",
              "  pm.expect(healthResponse.status).to.eql(\"ok\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create Item",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Desk Lamp\",\n  \"description\": \"Adjustable LED lamp\",\n  \"price\": 129\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "items"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 201\", function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "var createdItem = pm.response.json();",
              "pm.collectionVariables.set(\"itemId\", createdItem.id);",
              "pm.test(\"created item has id\", function () {",
              "  pm.expect(createdItem.id).to.be.a(\"number\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "List Items",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "items"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"response is an array\", function () {",
              "  var itemList = pm.response.json();",
              "  pm.expect(itemList).to.be.an(\"array\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Item By Id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/items/{{itemId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "items",
            "{{itemId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"item id matches saved id\", function () {",
              "  var selectedItem = pm.response.json();",
              "  pm.expect(String(selectedItem.id)).to.eql(String(pm.collectionVariables.get(\"itemId\")));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update Item",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Desk Lamp Pro\",\n  \"description\": \"Adjustable LED lamp with dimmer\",\n  \"price\": 159\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/items/{{itemId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "items",
            "{{itemId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test(\"item is updated\", function () {",
              "  var updatedItem = pm.response.json();",
              "  pm.expect(updatedItem.name).to.eql(\"Desk Lamp Pro\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete Item",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/items/{{itemId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "items",
            "{{itemId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 204\", function () {",
              "  pm.response.to.have.status(204);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Deleted Item",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/items/{{itemId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "items",
            "{{itemId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"status is 404\", function () {",
              "  pm.response.to.have.status(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "itemId",
      "value": ""
    }
  ]
}
