{
  "name": "present-code",
  "version": "1.0.0",
  "description": "Node.js Item CRUD API with Jest and Postman testing",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "npm run build && node dist/src/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:postman": "newman run postman/newman/Item-CRUD.postman_collection.json -e postman/newman/local.postman_environment.json",
    "test:ci": "npm run build && npm test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "express": "^5.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "newman": "^6.2.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
